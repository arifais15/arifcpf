rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES
     * 
     * This ruleset is configured for the PBS CPF Management prototype.
     * It allows all signed-in users (including Anonymous) to view data.
     * Administrative actions (create/update/delete) are restricted to users
     * with an entry in the 'roles_admin' collection.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Admin Roles Registry
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Chart of Accounts
    match /chartOfAccounts/{accountId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn(); // Permissive for prototype
    }

    // Members Registry (Employees)
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn(); // Permissive for prototype
      
      // Subcollection for Ledger Entries
      match /fundSummaries/{summaryId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

    // Investment Instruments
    match /investmentInstruments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }
    
    // Accrued Interest Logs
    match /accruedInterestLogs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }

    // Journal Entries
    match /journalEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
      
      // Line Items subcollection
      match /line_items/{lineId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

  }
}