
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES - PBS CPF SYSTEM
     * 
     * Allows access to authenticatedSamity personnel while
     * enforcing role-based controls for administrative collections.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      // Must be authenticated with a valid Samity account
      return request.auth != null;
    }

    function isAdmin() {
      // Check if user has an entry in roles_admin collection
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES (FOR AGGREGATE REPORTS) ---
    
    match /{path=**}/fundSummaries/{summaryId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/line_items/{lineId} {
      allow read: if isSignedIn();
    }

    // --- COLLECTION RULES ---

    // Admin Roles Registry
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Chart of Accounts (Institutional Standard)
    match /chartOfAccounts/{accountId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Members Registry (Samity Personnel)
    match /members/{memberId} {
      allow read, write: if isSignedIn();
      
      // Subcollection for Individual Subsidiary Ledgers
      match /fundSummaries/{summaryId} {
        allow read, write: if isSignedIn();
      }
    }

    // Investment Instruments Portfolio
    match /investmentInstruments/{id} {
      allow read, write: if isSignedIn();

      // Subcollection for Audit/Renewal History
      match /auditHistory/{historyId} {
        allow read, write: if isSignedIn();
      }
    }
    
    // Accrued Interest Logs (Year-end Provisions)
    match /accruedInterestLogs/{id} {
      allow read, write: if isSignedIn();
    }

    // Journal Entries (General Ledger)
    match /journalEntries/{entryId} {
      allow read, write: if isSignedIn();
      
      // Double-entry Line Items
      match /line_items/{lineId} {
        allow read, write: if isSignedIn();
      }
    }

    // System Settings (Account Mapping & Policy)
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

  }
}
