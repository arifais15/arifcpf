rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PBS CPF Management Accounting Software - Security Rules
     * 
     * UPDATED FOR PROTOTYPING:
     * To facilitate rapid development and CRUD testing, rules have been relaxed 
     * to allow access to all authenticated users (including anonymous ones).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /chartOfAccounts/{chartOfAccountId} {
      allow read, write: if isSignedIn();
    }

    match /members/{memberId} {
      allow read, write: if isSignedIn();

      match /fundSummaries/{summaryId} {
        allow read, write: if isSignedIn();
      }
    }

    match /journalEntries/{journalEntryId} {
      allow read, write: if isSignedIn();

      match /lineItems/{lineItemId} {
        allow read, write: if isSignedIn();
      }
    }

    match /investmentInstruments/{instrumentId} {
      allow read, write: if isSignedIn();
    }

    match /accruedInterestLogs/{accrualLogId} {
      allow read, write: if isSignedIn();
    }
  }
}
