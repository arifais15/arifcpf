
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES
     * 
     * This ruleset is configured for the PBS CPF Management system.
     * It strictly allows access only to authenticated Email/Password users.
     * Anonymous users are explicitly denied.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      // Must be signed in AND NOT anonymous
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAdmin() {
      // Check if user has an entry in roles_admin collection
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES (CRITICAL FOR REPORTS) ---
    
    // Allows collectionGroup('fundSummaries') queries used in Audit & Tracking
    match /{path=**}/fundSummaries/{summaryId} {
      allow read: if isSignedIn();
    }

    // Allows collectionGroup('line_items') queries if used for subsidiary ledgers
    match /{path=**}/line_items/{lineId} {
      allow read: if isSignedIn();
    }

    // --- COLLECTION RULES ---

    // Admin Roles Registry
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Chart of Accounts
    match /chartOfAccounts/{accountId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }

    // Members Registry (Employees)
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
      
      // Subcollection for Ledger Entries (Standard Path)
      match /fundSummaries/{summaryId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

    // Investment Instruments
    match /investmentInstruments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }
    
    // Accrued Interest Logs
    match /accruedInterestLogs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }

    // Journal Entries
    match /journalEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
      
      // Line Items subcollection
      match /line_items/{lineId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

  }
}
