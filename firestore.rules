rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PBS CPF Management Accounting Software - Security Rules
     * 
     * UPDATED FOR PROTOTYPING:
     * To prevent "Missing or insufficient permissions" errors during the initial 
     * anonymous authentication handshake, rules have been temporarily set to 
     * allow all read/write access. This ensures that real-time listeners (onSnapshot)
     * do not fail while the Firebase Auth session is being initialized.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}